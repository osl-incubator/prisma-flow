#!/usr/bin/env bash
set -euo pipefail

# Build prisma-flow using a local virtual environment. This is useful on
# systems where the conda/uv development environment is not available.
VENV_DIR="$(pwd)/.venv"

if [ ! -d "$VENV_DIR" ]; then
  echo "Creating Python virtual environment..."
  python -m venv "$VENV_DIR"
fi

# shellcheck source=/dev/null
source "$VENV_DIR/bin/activate"

echo "Installing build dependencies..."
pip install --upgrade pip
pip install build

echo "Building package..."
python -m build

deactivate

echo "Build completed successfully"
